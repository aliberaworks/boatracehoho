{
    "public": true,
    "rewrites": [
        { "source": "/(.*)", "destination": "/$1" }
    ],
    "headers": [
        {
            "source": "/data/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate" }
            ]
        }
    ]
}
